Ref        ::= Base [ Selector ]                  (* selector, if any, is LAST *)

Base       ::= IID [ "@" VID ] [ Component ]      (* Component is optional and unique *)

Component  ::= "#" RID | "\" CID                  (* at most one of these *)

Selector   ::= "[" SelBody "]"

SelBody    ::= TimeSel | CharSel | ByteSel | RectSel
TimeSel    ::= Number "-" Number "s"
CharSel    ::= "c:" Number "-" Number
ByteSel    ::= "b:" Number "-" Number
RectSel    ::= "rect:" Number "," Number "," Number "," Number

IID        ::= "iid:" IidBody
VID        ::= VidBody
RID        ::= RidBody
CID        ::= Alg ":" Hex
Alg        ::= "sha256" | "blake3" | <future>
Hex        ::= 1*HEXDIG
Number     ::= INT [ "." 1*DIGIT ]
IidBody    ::= 1*( ALPHA | DIGIT | "/" | "-" | "_" | "." )
VidBody    ::= 1*( ALPHA | DIGIT | "-" | "_" | "." )
RidBody    ::= 1*( ALPHA | DIGIT | "-" | "_" )
INT        ::= 1*DIGIT

RefText      ::= IIDText [ "@" VIDText ] [ CompText ] [ SelectorText ]
IIDText      ::= "iid:" MBHash
VIDText      ::= MBHash
CompText     ::= "#" MBHash | "\" MBHash
MBHash       ::= BasePrefix 1*BASECHAR
BasePrefix   ::= "z" | "u" | "m" | "b" | "f" | "k"  (* multibase prefixes; choose the subset you support *)
BASECHAR     ::= ALPHA | DIGIT | "-" | "_" | "~" | "." | "="  (* depends on base; validate per base *)

SelectorText ::= "[" TimeSel | CharSel | ByteSel | RectSel "]"
TimeSel      ::= Number "-" Number "s"
CharSel      ::= "c:" Number "-" Number
ByteSel      ::= "b:" Number "-" Number
RectSel      ::= "rect:" Number "," Number "," Number "," Number

Number       ::= INT [ "." 1*DIGIT ]
INT          ::= 1*DIGIT